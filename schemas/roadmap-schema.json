{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pivotmap.example/schemas/roadmap-schema.json",
  "title": "PivotMap ProofGraph",
  "type": "object",
  "required": ["user_id", "jd_text", "version", "created_at", "nodes", "edges"],
  "properties": {
    "user_id": {
      "type": "string"
    },
    "jd_text": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/proofNode"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "diff_from_prev": {
      "type": ["object", "null"],
      "properties": {
        "changed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "new": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "resolved": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stale": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "sourcedClaim": {
      "type": "object",
      "required": [
        "claim",
        "source_url",
        "published_at",
        "retrieved_at",
        "confidence"
      ],
      "properties": {
        "claim": {
          "type": "string"
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "published_at": {
          "type": "string",
          "format": "date-time"
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "source_type": {
          "type": ["string", "null"],
          "enum": [
            "job_post",
            "industry_report",
            "course_catalogue",
            "alumni_pattern",
            null
          ]
        },
        "uncertainty_note": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    },
    "jdRequirement": {
      "type": "object",
      "required": ["skill", "importance", "category", "confidence", "sources"],
      "properties": {
        "skill": {
          "type": "string"
        },
        "importance": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "category": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sourcedClaim"
          }
        }
      },
      "additionalProperties": false
    },
    "studentEvidence": {
      "type": "object",
      "required": ["type", "title", "skills_proven", "strength"],
      "properties": {
        "type": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "skills_proven": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "strength": {
          "type": "string",
          "enum": ["strong", "weak"]
        }
      },
      "additionalProperties": false
    },
    "proofNode": {
      "type": "object",
      "required": ["requirement", "status", "evidence", "gap_action", "resume_bullet", "sources"],
      "properties": {
        "requirement": {
          "$ref": "#/$defs/jdRequirement"
        },
        "status": {
          "type": "string",
          "enum": ["matched", "weak", "missing"]
        },
        "evidence": {
          "type": ["array", "null"],
          "items": {
            "$ref": "#/$defs/studentEvidence"
          }
        },
        "gap_action": {
          "type": ["string", "null"]
        },
        "resume_bullet": {
          "type": ["string", "null"]
        },
        "sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sourcedClaim"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
