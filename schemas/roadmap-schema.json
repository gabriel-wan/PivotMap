{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pivotmap.example/schemas/career-proof-graph.json",
  "title": "PivotMap Career Proof Graph",
  "type": "object",
  "required": [
    "user_id",
    "sources",
    "evidence_nodes",
    "claim_nodes",
    "skill_nodes",
    "gap_nodes",
    "trace_events"
  ],
  "properties": {
    "user_id": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source"
      }
    },
    "evidence_nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidenceNode"
      }
    },
    "claim_nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claimNode"
      }
    },
    "skill_nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/skillNode"
      }
    },
    "gap_nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gapNode"
      }
    },
    "trace_events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/traceEvent"
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": [
        "id",
        "source_url",
        "source_type",
        "title",
        "published_at",
        "retrieved_at",
        "metadata"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "source_url": {
          "type": "string"
        },
        "source_type": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "published_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "evidenceNode": {
      "type": "object",
      "required": [
        "id",
        "user_id",
        "kind",
        "title",
        "description",
        "source_ids",
        "created_at",
        "metadata"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "user_id": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": ["module", "experience", "project", "resume", "voice"]
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "source_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "claimNode": {
      "type": "object",
      "required": [
        "id",
        "evidence_id",
        "claim_text",
        "confidence_status",
        "confidence_score",
        "source_ids",
        "created_at"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "evidence_id": {
          "type": "string"
        },
        "claim_text": {
          "type": "string"
        },
        "confidence_status": {
          "type": "string",
          "enum": ["verified", "supported", "user-attested", "weak", "missing"]
        },
        "confidence_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "source_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "skillNode": {
      "type": "object",
      "required": [
        "id",
        "user_id",
        "skill",
        "category",
        "confidence_score",
        "evidence_ids",
        "claim_ids",
        "created_at"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "user_id": {
          "type": "string"
        },
        "skill": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "confidence_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "claim_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "gapNode": {
      "type": "object",
      "required": [
        "id",
        "user_id",
        "target_role",
        "requirement",
        "status",
        "recommended_action",
        "linked_evidence_ids",
        "source_ids",
        "created_at"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "user_id": {
          "type": "string"
        },
        "target_role": {
          "type": "string"
        },
        "requirement": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["matched", "weak", "missing"]
        },
        "recommended_action": {
          "type": ["string", "null"]
        },
        "linked_evidence_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "traceEvent": {
      "type": "object",
      "required": [
        "id",
        "user_id",
        "run_id",
        "stage",
        "message",
        "created_at",
        "metadata"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "user_id": {
          "type": "string"
        },
        "run_id": {
          "type": "string"
        },
        "stage": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
